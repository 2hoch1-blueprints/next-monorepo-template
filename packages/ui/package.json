{
  "name": "@workspace/ui",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./components/button": {
      "react-server": "./src/components/button.tsx",
      "import": "./dist/button.js",
      "types": "./src/components/button.tsx",
      "default": "./src/components/button.tsx"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown --entry.button src/components/button.tsx",
    "dev": "tsdown --entry.button src/components/button.tsx --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@workspace/utils": "workspace:*",
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@workspace/eslint": "workspace:*",
    "@workspace/typescript": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.12.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  }
}
